{
  "name": "luizhenriquedigital/laravel-upload-manager",
  "description": "Gerenciador de uploads fluente para Laravel",
  "license": "MIT",
  "authors": [
    {
      "name": "Luiz Henrique Digital",
      "email": "luizhenriquedigital@gmail.com"
    }
  ],
  "autoload": {
    "psr-4": {
      "LuizHenriqueDigital\\UploadManager\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "LuizHenriqueDigital\\UploadManager\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "LuizHenriqueDigital\\UploadManager\\UploadServiceProvider"
      ],
      "aliases": {
        "Upload": "LuizHenriqueDigital\\UploadManager\\Facades\\Upload"
      }
    }
  },
  "require": {
    "php": "^7.3|^8.0",
    "illuminate/support": "^7.0|^8.0|^9.0|^10.0|^11.0",
    "illuminate/filesystem": "^7.0|^8.0|^9.0|^10.0|^11.0",
    "illuminate/http": "^7.0|^8.0|^9.0|^10.0|^11.0"
  },
  "require-dev": {
    "orchestra/testbench": "^5.0|^6.0|^7.0|^8.0|^9.0",
    "pestphp/pest": "^1.0",
    "pestphp/pest-plugin-laravel": "^1.0"
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  }
}
